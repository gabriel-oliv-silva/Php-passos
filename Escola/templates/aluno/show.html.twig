{% extends 'base.html.twig' %}

{% block title %}Detalhes do Aluno{% endblock %}

{% block body %}
<div class="container mt-5">

    <div class="card shadow-sm">
        <div class="card-header bg-primary text-white">
            <h4 class="mb-0">👤 Detalhes do Aluno</h4>
        </div>

        <div class="card-body">
            <table class="table table-bordered mb-0">
                <tbody>
                    <tr>
                        <th style="width: 150px;">ID</th>
                        <td>{{ aluno.id }}</td>
                    </tr>
                    <tr>
                        <th>Nome</th>
                        <td>{{ aluno.nome }}</td>
                    </tr>
                    <tr>
                        <th>Idade</th>
                        <td>{{ aluno.idade }}</td>
                    </tr>
                    <tr>
                        <th>Email</th>
                        <td>{{ aluno.email ?: '—' }}</td>
                    </tr>
                </tbody>
            </table>
        </div>

        <div class="card-footer d-flex justify-content-between">
            <a href="{{ path('app_aluno_index') }}" class="btn btn-secondary">
                ⬅ Voltar
            </a>

            <div class="d-flex gap-2">
                <a href="{{ path('app_aluno_edit', {'id': aluno.id}) }}" class="btn btn-warning">
                    ✏ Editar
                </a>

                {{ include('aluno/_delete_form.html.twig') }}
            </div>
        </div>
    </div>

</div>
{% endblock %}